#!/bin/bash
# Pre-commit hook: validates staged HTML files before committing
# Installed via: git config core.hooksPath .githooks

staged_html=$(git diff --cached --name-only --diff-filter=ACM -- '*.html')

if [ -z "$staged_html" ]; then
  exit 0
fi

if [ ! -f "./validate-html.sh" ]; then
  echo "Warning: validate-html.sh not found, skipping validation"
  exit 0
fi

echo "Validating staged HTML files..."
bash ./validate-html.sh $staged_html
