{
    "includeCoAuthoredBy": false,
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash ./validate-html.sh $(git diff --cached --name-only --diff-filter=ACM -- '*.html')",
                        "if": "Bash(git commit*)"
                    }
                ]
            }
        ]
    }
}
